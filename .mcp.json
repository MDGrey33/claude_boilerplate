{
  "mcpServers": {
    "cognee": {
      "command": "uvx",
      "args": ["--from", "cognee-mcp", "cognee-mcp"],
      "env": {
        "LLM_API_KEY": "${LLM_API_KEY}",
        "DB_PROVIDER": "postgres",
        "DB_HOST": "127.0.0.1",
        "DB_PORT": "5432",
        "DB_USERNAME": "cognee",
        "DB_PASSWORD": "cognee",
        "DB_NAME": "cognee_db",
        "VECTOR_DB_PROVIDER": "pgvector"
      }
    }
  }
}
